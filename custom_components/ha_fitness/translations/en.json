  "services": {
    "start_workout": {
      "name": "Start Workout",
      "description": "Starts a workout with two-step confirmation by default in the calling Home Assistant user context.",
      "fields": {
        "force": {
          "name": "Force",
          "description": "If true, start the workout immediately and bypass confirmation."
        }
      }
    },
    "finish_workout": {
      "name": "Finish Workout",
      "description": "Finishes a workout with two-step confirmation by default in the calling Home Assistant user context.",
      "fields": {
        "force": {
          "name": "Force",
          "description": "If true, finish the workout immediately and bypass confirmation."
        }
      }
    },
    "save_set": {
      "name": "Save Set",
      "description": "Logs a completed exercise set. Exercise can be an exercise_id or a display name. Weight (>0) and reps (>0) are required. If no workout is active, an implicit workout is created and finished automatically.",
      "fields": {
        "exercise": {
          "name": "Exercise",
          "description": "Name of the exercise performed."
        },
        "weight": {
          "name": "Weight",
          "description": "Weight used (in kg or lb)."
        },
        "reps": {
          "name": "Reps",
          "description": "Number of repetitions completed."
        },
        "notes": {
          "name": "Notes",
          "description": "Optional notes about the set."
        }
      }
    },
    "refresh_statistics": {
      "name": "Refresh Statistics",
      "description": "Refreshes totals, PR values, and recent sets from SQLite."
    },
    "export_data": {
      "name": "Export Data",
      "description": "Exports totals, PR values, and recent sets to /config/ha_fitness/export.json."
    },
    "save_current_set": {
      "name": "Save Current Set",
      "description": "Saves a set from current runtime inputs for the calling Home Assistant user context."
    },
    "select_user": {
      "name": "Select User",
      "description": "Selects the user id used for personal dashboard statistics.",
      "fields": {
        "user_id": {
          "name": "User ID",
          "description": "Optional known HAGym user id."
        }
      }
    },
    "refresh_users": {
      "name": "Refresh Users",
      "description": "Refreshes known users from SQLite and updates statistics."
    },
    "add_exercise": {
      "name": "Add Exercise",
      "description": "Adds or reactivates an exercise in the SQLite catalog and refreshes runtime exercise options/statistics."
    },
    "update_exercise": {
      "name": "Update Exercise",
      "description": "Updates exercise catalog metadata by exercise_id and refreshes runtime exercise options/statistics."
    },
    "disable_exercise": {
      "name": "Disable Exercise",
      "description": "Disables an exercise by exercise_id so it no longer appears in active exercise options."
    },
    "refresh_exercises": {
      "name": "Refresh Exercises",
      "description": "Re-seeds default built-in exercises in SQLite and refreshes runtime exercise options/statistics."
    },
    "select_equipment": {
      "name": "Select Equipment",
      "description": "Sets the active equipment filter for workout views.",
      "fields": {
        "equipment_id": {
          "name": "Equipment ID",
          "description": "Optional equipment id. Empty means show all exercises."
        }
      }
    },
    "add_muscle_group": {
      "name": "Add Muscle Group",
      "description": "Adds or reactivates a muscle group in the SQLite catalog and refreshes muscle group statistics."
    },
    "update_muscle_group": {
      "name": "Update Muscle Group",
      "description": "Updates muscle group metadata by muscle_group_id and refreshes muscle group statistics."
    },
    "disable_muscle_group": {
      "name": "Disable Muscle Group",
      "description": "Disables a muscle group by muscle_group_id so it no longer appears in active muscle group options."
    },
    "assign_muscle_group_to_exercise": {
      "name": "Assign Muscle Group to Exercise",
      "description": "Assigns one muscle group to one exercise with role and weight factor."
    },
    "refresh_muscle_groups": {
      "name": "Refresh Muscle Groups",
      "description": "Refreshes muscle group catalog and derived muscle group statistics."
    },
    "create_workout": {
      "name": "Create Workout",
      "description": "Creates a workout manually with start/end timestamps."
    },
    "update_workout": {
      "name": "Update Workout",
      "description": "Updates one workout by workout_id."
    },
    "delete_workout": {
      "name": "Delete Workout",
      "description": "Deletes a workout and optionally all related set rows."
    },
    "add_set_to_workout": {
      "name": "Add Set to Workout",
      "description": "Adds a set to an existing workout."
    },
    "update_set": {
      "name": "Update Set",
      "description": "Updates one set by set_id."
    },
    "delete_set": {
      "name": "Delete Set",
      "description": "Deletes one set by set_id."
    },
    "save_activity": {
      "name": "Save Activity",
      "description": "Saves a non-strength activity entry (for example cardio, duration, hold) into set_logs.",
      "fields": {
        "exercise_id": {
          "name": "Exercise ID",
          "description": "Target exercise from the exercise catalog."
        },
        "metric_type": {
          "name": "Metric type",
          "description": "Activity metric type (must not be strength)."
        },
        "duration_seconds": {
          "name": "Duration (seconds)",
          "description": "Activity duration in seconds."
        },
        "distance_m": {
          "name": "Distance (m)",
          "description": "Distance in meters."
        },
        "calories": {
          "name": "Calories",
          "description": "Estimated calories."
        },
        "steps": {
          "name": "Steps",
          "description": "Step count."
        },
        "avg_heart_rate": {
          "name": "Avg heart rate",
          "description": "Average heart rate."
        },
        "max_heart_rate": {
          "name": "Max heart rate",
          "description": "Maximum heart rate."
        },
        "source": {
          "name": "Source",
          "description": "Optional source of the entry."
        }
      }
    }
  },
